# ============================================================================
# Pulsar — environment variables
# Copy to .env in each of server/ and worker/ (docker-compose already wires
# these automatically via docker/docker-compose.yml).
# ============================================================================

# --- Shared -----------------------------------------------------------------
DATABASE_URL="postgresql://pulsar:pulsar@localhost:5432/pulsar?schema=public"
NODE_ENV=development

# --- server/.env --------------------------------------------------------------
PORT=4000
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# --- worker/.env --------------------------------------------------------------
WORKER_NAME=worker-1
WORKER_CONCURRENCY=4
POLL_INTERVAL_MS=1000
HEARTBEAT_INTERVAL_MS=5000
API_BASE_URL=http://localhost:4000
