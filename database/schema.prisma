// ============================================================================
// Pulsar — Prisma schema (PostgreSQL)
// Normalized schema for the distributed job scheduling platform.
// Every table: UUID PK, created_at, updated_at, indexes, FKs with cascade rules.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DEVELOPER
  VIEWER
}

enum RetryStrategy {
  FIXED
  LINEAR
  EXPONENTIAL
}

enum JobType {
  IMMEDIATE
  DELAYED
  SCHEDULED
  RECURRING
  BATCH
}

enum JobStatus {
  QUEUED
  SCHEDULED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  RETRYING
  DEAD_LETTER
  CANCELLED
}

enum ExecutionStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum WorkerStatus {
  ONLINE
  BUSY
  OFFLINE
}

enum LogLevel {
  debug
  info
  warn
  error
}

enum BatchStatus {
  PENDING
  RUNNING
  COMPLETED
  PARTIAL_FAILURE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ownedOrganizations Organization[]       @relation("OrgOwner")
  memberships        OrganizationMember[]

  @@map("users")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner    User                 @relation("OrgOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  OrganizationMember[]
  projects Project[]

  @@index([ownerId])
  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           Role     @default(VIEWER)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Project {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  description    String   @default("")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  queues       Queue[]

  @@index([organizationId])
  @@map("projects")
}

model RetryPolicy {
  id           String        @id @default(uuid())
  name         String
  strategy     RetryStrategy @default(EXPONENTIAL)
  baseDelayMs  Int           @map("base_delay_ms")
  maxDelayMs   Int           @map("max_delay_ms")
  maxAttempts  Int           @map("max_attempts")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  queues Queue[]

  @@map("retry_policies")
}

model Queue {
  id                String   @id @default(uuid())
  projectId         String   @map("project_id")
  name              String
  description       String   @default("")
  priority          Int      @default(5)
  concurrencyLimit  Int      @default(2) @map("concurrency_limit")
  isPaused          Boolean  @default(false) @map("is_paused")
  retryPolicyId     String   @map("retry_policy_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  retryPolicy   RetryPolicy    @relation(fields: [retryPolicyId], references: [id], onDelete: Restrict)
  jobs          Job[]
  recurringJobs RecurringJob[]
  batchJobs     BatchJob[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("queues")
}

model Job {
  id             String    @id @default(uuid())
  queueId        String    @map("queue_id")
  batchId        String?   @map("batch_id")
  recurringJobId String?   @map("recurring_job_id")
  name           String
  type           JobType   @default(IMMEDIATE)
  status         JobStatus @default(QUEUED)
  payload        Json
  priority       Int       @default(5)
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3) @map("max_attempts")
  runAt          DateTime  @default(now()) @map("run_at")
  claimedBy      String?   @map("claimed_by")
  claimedAt      DateTime? @map("claimed_at")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  lastError      String?   @map("last_error")
  durationMs     Int?      @map("duration_ms")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  queue         Queue         @relation(fields: [queueId], references: [id], onDelete: Cascade)
  batch         BatchJob?     @relation(fields: [batchId], references: [id], onDelete: SetNull)
  recurringJob  RecurringJob? @relation(fields: [recurringJobId], references: [id], onDelete: SetNull)
  worker        Worker?       @relation(fields: [claimedBy], references: [id], onDelete: SetNull)
  scheduledJob  ScheduledJob?
  executions    JobExecution[]
  executionLogs ExecutionLog[]
  deadLetter    DeadLetterQueue?

  // Composite index accelerates the atomic claim query:
  // SELECT ... WHERE status = 'QUEUED' AND run_at <= now() ORDER BY priority DESC FOR UPDATE SKIP LOCKED
  @@index([status, runAt])
  @@index([queueId, status])
  @@index([priority])
  @@index([batchId])
  @@map("jobs")
}

model ScheduledJob {
  id           String   @id @default(uuid())
  jobId        String   @unique @map("job_id")
  scheduledFor DateTime @map("scheduled_for")
  executed     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([scheduledFor])
  @@map("scheduled_jobs")
}

model RecurringJob {
  id              String    @id @default(uuid())
  queueId         String    @map("queue_id")
  name            String
  cronExpression  String    @map("cron_expression")
  payloadTemplate Json      @map("payload_template")
  isActive        Boolean   @default(true) @map("is_active")
  nextRunAt       DateTime  @map("next_run_at")
  lastRunAt       DateTime? @map("last_run_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  queue Queue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  jobs  Job[]

  @@index([queueId])
  @@index([nextRunAt, isActive])
  @@map("recurring_jobs")
}

model BatchJob {
  id             String      @id @default(uuid())
  queueId        String      @map("queue_id")
  name           String
  totalJobs      Int         @map("total_jobs")
  completedJobs  Int         @default(0) @map("completed_jobs")
  failedJobs     Int         @default(0) @map("failed_jobs")
  status         BatchStatus @default(PENDING)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  queue Queue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  jobs  Job[]

  @@index([queueId])
  @@map("batch_jobs")
}

model JobExecution {
  id            String          @id @default(uuid())
  jobId         String          @map("job_id")
  workerId      String          @map("worker_id")
  attemptNumber Int             @map("attempt_number")
  status        ExecutionStatus @default(RUNNING)
  startedAt     DateTime        @map("started_at")
  completedAt   DateTime?       @map("completed_at")
  durationMs    Int?            @map("duration_ms")
  errorMessage  String?         @map("error_message")
  errorStack    String?         @map("error_stack")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  job           Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker        Worker         @relation(fields: [workerId], references: [id], onDelete: Cascade)
  executionLogs ExecutionLog[]

  @@index([jobId])
  @@index([workerId])
  @@map("job_executions")
}

model Worker {
  id              String       @id @default(uuid())
  name            String
  hostname        String
  status          WorkerStatus @default(ONLINE)
  concurrency     Int          @default(2)
  cpuUsage        Float        @default(0) @map("cpu_usage")
  memoryUsage     Float        @default(0) @map("memory_usage")
  lastHeartbeatAt DateTime     @default(now()) @map("last_heartbeat_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  jobs       Job[]
  executions JobExecution[]
  heartbeats WorkerHeartbeat[]

  @@index([status])
  @@map("workers")
}

model WorkerHeartbeat {
  id          String   @id @default(uuid())
  workerId    String   @map("worker_id")
  cpuUsage    Float    @map("cpu_usage")
  memoryUsage Float    @map("memory_usage")
  activeJobs  Int      @map("active_jobs")
  timestamp   DateTime @default(now())

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, timestamp])
  @@map("worker_heartbeats")
}

model ExecutionLog {
  id             String   @id @default(uuid())
  jobExecutionId String?  @map("job_execution_id")
  jobId          String   @map("job_id")
  level          LogLevel @default(info)
  message        String
  timestamp      DateTime @default(now())

  job          Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobExecution JobExecution? @relation(fields: [jobExecutionId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([jobExecutionId])
  @@map("execution_logs")
}

model DeadLetterQueue {
  id              String   @id @default(uuid())
  jobId           String   @unique @map("job_id")
  queueId         String   @map("queue_id")
  reason          String
  attemptsMade    Int      @map("attempts_made")
  payloadSnapshot Json     @map("payload_snapshot")
  failedAt        DateTime @map("failed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([queueId])
  @@map("dead_letter_queue")
}
